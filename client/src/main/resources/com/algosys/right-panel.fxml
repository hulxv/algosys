<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.LineChart?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rightPanelRoot" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.algosys.controller.RightPanelController" 
      styleClass="right-panel-container" spacing="20" style="-fx-padding: 20;" VBox.vgrow="ALWAYS">
    
    <VBox fx:id="rightSectionsWrapper" spacing="20" styleClass="right-sections-wrapper" VBox.vgrow="ALWAYS">

    <!-- Estimated Complexity Section -->
    <VBox spacing="8" styleClass="complexity-section right-panel-section">
        <HBox spacing="6" alignment="CENTER_LEFT">
            <Label text="◯" style="-fx-text-fill: #00c7c7; -fx-font-size: 10px;" />
            <Label text="ESTIMATED COMPLEXITY" styleClass="section-title" />
        </HBox>
        
        <HBox spacing="18" alignment="TOP_LEFT">
            <!-- Complexity Value -->
            <VBox spacing="4" alignment="TOP_LEFT" minWidth="220" prefWidth="220">
                <Label fx:id="complexityValue" text="--" maxWidth="Infinity" styleClass="complexity-value" />
                <Label fx:id="complexityName" text="Awaiting run" styleClass="complexity-name complexity-subtitle" wrapText="true" />
            </VBox>
            
            <!-- Complexity Description -->
            <Label fx:id="complexityDescription" text="Run an analysis to benchmark your snippet against the API." styleClass="complexity-description" wrapText="true" HBox.hgrow="ALWAYS" />
        </HBox>
    </VBox>
    
    <!-- Metrics Cards Section -->
    <HBox spacing="12" styleClass="metrics-container right-panel-section" minHeight="100">
        <!-- MIN TIME Card -->
        <VBox styleClass="metric-card" HBox.hgrow="ALWAYS" maxWidth="Infinity" minWidth="0.0" alignment="CENTER_LEFT">
            <Label text="MIN TIME" styleClass="metric-label" />
            <Label fx:id="minTimeValue" text="0.00ms" styleClass="metric-value metric-value-min" style="-fx-text-fill: #00c7c7;" />
        </VBox>
        
        <!-- MAX TIME Card -->
        <VBox styleClass="metric-card" HBox.hgrow="ALWAYS" maxWidth="Infinity" minWidth="0.0" alignment="CENTER_LEFT">
            <Label text="MAX TIME" styleClass="metric-label" />
            <Label fx:id="maxTimeValue" text="0.00ms" styleClass="metric-value metric-value-max" style="-fx-text-fill: #f2b84b;" />
        </VBox>
        
        <!-- DATA POINTS Card -->
        <VBox styleClass="metric-card" HBox.hgrow="ALWAYS" maxWidth="Infinity" minWidth="0.0" alignment="CENTER_LEFT">
            <Label text="DATA POINTS" styleClass="metric-label" />
            <Label fx:id="dataPointsValue" text="0" styleClass="metric-value" />
        </VBox>
        
        <!-- MODE Card -->
        <VBox styleClass="metric-card" HBox.hgrow="ALWAYS" maxWidth="Infinity" minWidth="0.0" alignment="CENTER_LEFT">
            <Label text="MODE" styleClass="metric-label" />
            <Label fx:id="modeValue" text="Mode 2" styleClass="metric-value" />
        </VBox>
        
        <!-- RATIO Card -->
        <VBox styleClass="metric-card" HBox.hgrow="ALWAYS" maxWidth="Infinity" minWidth="0.0" alignment="CENTER_LEFT">
            <Label text="RATIO (MAX/MIN)" styleClass="metric-label" />
            <Label fx:id="ratioValue" text="0.0x" styleClass="metric-value" />
        </VBox>
    </HBox>
    
    <!-- Chart Section -->
    <VBox spacing="8" VBox.vgrow="ALWAYS" styleClass="chart-section right-panel-section">
        <HBox spacing="6" alignment="CENTER_LEFT">
            <Label text="⚡" style="-fx-text-fill: #00c7c7; -fx-font-size: 10px;" />
            <Label text="EXECUTION TIME VS INPUT SIZE" styleClass="section-title" />
            <Region HBox.hgrow="ALWAYS" />
            <Label fx:id="chartComplexityValue" text="--" style="-fx-text-fill: #00c7c7; -fx-font-size: 10px; -fx-font-weight: 700;" />
        </HBox>
        
        <LineChart fx:id="executionChart" 
                   title=""
                   animated="false"
                   VBox.vgrow="ALWAYS"
                   styleClass="execution-chart">
            <xAxis>
                <NumberAxis fx:id="xAxis" label="Input Size (n)" lowerBound="0" upperBound="10000" />
            </xAxis>
            <yAxis>
                <NumberAxis fx:id="yAxis" label="Execution Time" lowerBound="0" upperBound="200" />
            </yAxis>
        </LineChart>
    </VBox>
    
    <!-- Complexity Reference Section -->
    <FlowPane hgap="12" vgap="10" styleClass="complexity-reference right-panel-section" minHeight="50">
        <Label text="COMPLEXITY REFERENCE" styleClass="section-title" />

        <HBox fx:id="constantPill" spacing="8" alignment="CENTER" styleClass="complexity-pill">
            <Label fx:id="constantDot" text="●" style="-fx-text-fill: #546082; -fx-font-size: 8px;" />
            <Label fx:id="constantLabel" text="O(1)" styleClass="complexity-btn" />
        </HBox>

        <HBox fx:id="logPill" spacing="8" alignment="CENTER" styleClass="complexity-pill">
            <Label fx:id="logDot" text="●" style="-fx-text-fill: #00c7c7; -fx-font-size: 8px;" />
            <Label fx:id="logLabel" text="O(log n)" styleClass="complexity-btn" />
        </HBox>

        <HBox fx:id="linearPill" spacing="8" alignment="CENTER" styleClass="complexity-pill">
            <Label fx:id="linearDot" text="●" style="-fx-text-fill: #00c7c7; -fx-font-size: 8px;" />
            <Label fx:id="linearLabel" text="O(n)" styleClass="complexity-btn" />
        </HBox>

        <HBox fx:id="linearithmicPill" spacing="8" alignment="CENTER" styleClass="complexity-pill">
            <Label fx:id="linearithmicDot" text="●" style="-fx-text-fill: #f2b84b; -fx-font-size: 8px;" />
            <Label fx:id="linearithmicLabel" text="O(n log n)" styleClass="complexity-btn" />
        </HBox>

        <HBox fx:id="quadraticPill" spacing="8" alignment="CENTER" styleClass="complexity-pill">
            <Label fx:id="quadraticDot" text="●" style="-fx-text-fill: #ff5f57; -fx-font-size: 8px;" />
            <Label fx:id="quadraticLabel" text="O(n^2)" styleClass="complexity-btn" />
        </HBox>

        <HBox fx:id="cubicPill" spacing="8" alignment="CENTER" styleClass="complexity-pill">
            <Label fx:id="cubicDot" text="●" style="-fx-text-fill: #ff5f57; -fx-font-size: 8px;" />
            <Label fx:id="cubicLabel" text="O(n^3)" styleClass="complexity-btn" />
        </HBox>

        <HBox fx:id="exponentialPill" spacing="8" alignment="CENTER" styleClass="complexity-pill">
            <Label fx:id="exponentialDot" text="●" style="-fx-text-fill: #ff5f57; -fx-font-size: 8px;" />
            <Label fx:id="exponentialLabel" text="O(2^n)" styleClass="complexity-btn" />
        </HBox>
    </FlowPane>

    </VBox> <!-- end rightSectionsWrapper -->
</VBox>
