{
  "name": "AlgoSys Server",
  "image": "metacall/core:dev",
  "workspaceFolder": "/workspaces/algosys",
  "postCreateCommand": "pip3 install --break-system-packages -r server/requirements.txt",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/bin/python3"
      }
    }
  }
}
